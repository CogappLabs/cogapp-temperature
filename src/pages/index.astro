---
import Base from "../layouts/Base.astro";
import ReadingCard from "../components/ReadingCard.astro";
import {
  FEEDS,
  getReading,
  getHistoryRange,
  tempBand,
  humidityBand,
  TEMP_SCALE,
  HUMIDITY_SCALE,
} from "../lib/adafruit";

const DEFAULT_RANGE = "24h";
const DEFAULT_HOURS = 24;

const [temp, hum, tempHist, humHist] = await Promise.all([
  getReading(FEEDS.temperature),
  getReading(FEEDS.humidity),
  getHistoryRange(FEEDS.temperature, DEFAULT_HOURS),
  getHistoryRange(FEEDS.humidity, DEFAULT_HOURS),
]);

const tBand = tempBand(temp.latest);
const hBand = humidityBand(hum.latest);

const updated = new Date(
  Math.max(new Date(temp.at).getTime(), new Date(hum.at).getTime()),
);
---

<Base title="Cogapp office habitability">
  <main
    class="mx-auto flex min-h-dvh max-w-2xl flex-col justify-center gap-[clamp(0.75rem,2.5vh,1.5rem)] px-5 py-6"
  >
    <header>
      <p class="font-sans text-xs uppercase tracking-widest text-grey m-0">
        Cogapp office
      </p>
      <h1
        class="font-serif leading-tight mt-1 mb-0 text-[clamp(1.75rem,5vw,3rem)]"
      >
        Office conditions
      </h1>
    </header>

    <p
      data-offline
      role="status"
      hidden
      class="rounded-xl bg-slate px-4 py-2 text-center font-sans text-sm text-cream"
    >
      Can’t reach the sensors. Showing the last known readings.
    </p>

    <div class="grid gap-[clamp(0.75rem,2vh,1.5rem)]">
      <ReadingCard
        id="temperature"
        label="Temperature"
        latest={temp.latest}
        unit="°C"
        band={tBand}
        points={temp.history}
        stroke="#c0392b"
        fill="#ffdaea"
        feedKey={FEEDS.temperature}
        historyPoints={tempHist}
        defaultRange={DEFAULT_RANGE}
        scale={TEMP_SCALE}
      />
      <ReadingCard
        id="humidity"
        label="Humidity"
        latest={hum.latest}
        unit="%"
        band={hBand}
        points={hum.history}
        stroke="#2471a3"
        fill="#dae9ff"
        feedKey={FEEDS.humidity}
        historyPoints={humHist}
        defaultRange={DEFAULT_RANGE}
        scale={HUMIDITY_SCALE}
      />
    </div>

    <footer class="mt-8 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-grey font-mono">
      <button
        type="button"
        data-refresh
        class="inline-flex items-center gap-1.5 rounded-full border border-slate/20 pl-2 pr-3 py-1 min-h-6 hover:border-slate/50 transition-colors disabled:opacity-50"
        aria-label="Refresh now"
      >
        <svg
          data-refresh-icon
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12a9 9 0 1 1-2.64-6.36"></path>
          <path d="M21 3v6h-6"></path>
        </svg>
        <span>Refresh</span>
      </button>
      <span>Next in <span data-countdown class="tabular-nums">60</span>s</span>
      <span class="basis-full sm:basis-auto">
        <span>Updated{" "}</span>
        <time data-updated datetime={updated.toISOString()}>
          {updated.toLocaleTimeString("en-GB")}
        </time>
        <span>{" "}· Data from{" "}</span>
        <a
          class="underline"
          href="https://io.adafruit.com/tristanr/dashboards/cogapp-office-habitability"
          >Adafruit IO</a
        >
        <span>{" "}·{" "}</span>
        <a class="underline" href="https://github.com/CogappLabs/cogapp-temperature"
          >GitHub</a
        >
      </span>
    </footer>
  </main>

  <script>
    import "../scripts/live.ts";
    import "../scripts/history.ts";
  </script>
</Base>
