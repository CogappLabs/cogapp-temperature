---
import Base from "../layouts/Base.astro";
import ReadingCard from "../components/ReadingCard.astro";
import OutdoorCard from "../components/OutdoorCard.astro";
import { FEEDS, TEMP_SCALE, HUMIDITY_SCALE } from "../lib/adafruit";
import { weather } from "../lib/weather";

// Nothing is fetched at build time: the page ships an empty placeholder and the
// client scripts fetch live data on load. This avoids baking a stale snapshot
// (the readings as they were when the site was last built) into the HTML.
const DEFAULT_RANGE = "24h";
---

<Base title="Cogapp office habitability">
  <main
    class="mx-auto flex min-h-dvh max-w-2xl flex-col justify-center gap-[clamp(0.75rem,2.5vh,1.5rem)] px-5 py-6"
  >
    <header>
      <div class="flex items-center justify-between gap-3">
        <h1 class="font-sans text-xs uppercase tracking-widest text-grey m-0">
          Cogapp conditions
        </h1>
        <div class="flex shrink-0 items-center gap-2 font-mono text-sm text-grey">
          <span
            data-timer
            class="relative inline-flex h-6 w-6 items-center justify-center"
            role="timer"
            aria-label="Time until next refresh"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
              <circle
                cx="12"
                cy="12"
                r="10"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="opacity-20"></circle>
              <circle
                data-timer-ring
                cx="12"
                cy="12"
                r="10"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                transform="rotate(-90 12 12)"
                stroke-dasharray="62.83"
                stroke-dashoffset="0"></circle>
            </svg>
          </span>
          <button
            type="button"
            data-refresh
            class="inline-flex items-center gap-1.5 rounded-full border border-slate/20 pl-2 pr-3 py-1 min-h-6 hover:border-slate/50 transition-colors disabled:opacity-50"
            aria-label="Refresh now"
          >
            <svg
              data-refresh-icon
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12a9 9 0 1 1-2.64-6.36"></path>
              <path d="M21 3v6h-6"></path>
            </svg>
            <span>Refresh</span>
          </button>
        </div>
      </div>
    </header>

    <p
      data-offline
      role="status"
      hidden
      class="rounded-xl bg-slate px-4 py-2 text-center font-sans text-sm text-cream"
    >
      Can’t reach the sensors right now. Retrying shortly.
    </p>

    <div class="grid gap-[clamp(0.75rem,2vh,1.5rem)]">
      <ReadingCard
        id="temperature"
        label="Temperature"
        unit="°C"
        stroke="#c0392b"
        fill="#ffdaea"
        feedKey={FEEDS.temperature}
        defaultRange={DEFAULT_RANGE}
        scale={TEMP_SCALE}
      />
      <ReadingCard
        id="humidity"
        label="Humidity"
        unit="%"
        stroke="#2471a3"
        fill="#dae9ff"
        feedKey={FEEDS.humidity}
        defaultRange={DEFAULT_RANGE}
        scale={HUMIDITY_SCALE}
      />
      <OutdoorCard />
    </div>

    <footer class="-mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-grey font-mono">
      <span>
        <span>Updated{" "}</span>
        <time data-updated>—</time>
        <span>{" "}· Data from{" "}</span>
        <a
          class="underline"
          href="https://io.adafruit.com/tristanr/dashboards/cogapp-office-habitability"
          >Adafruit IO</a
        >, <a class="underline" href={weather.url} rel="noopener">{weather.name}</a>
      </span>
      <a
        class="underline ml-auto"
        href="https://github.com/CogappLabs/cogapp-temperature">GitHub</a
      >
    </footer>
  </main>

  <script>
    import "../scripts/live.ts";
    import "../scripts/history.ts";
    import "../scripts/outdoor-history.ts";
  </script>
</Base>
