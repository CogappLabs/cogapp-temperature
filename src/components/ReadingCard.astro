---
import Sparkline from "./Sparkline.astro";
import HistoryPanel from "./HistoryPanel.astro";
import BandScale from "./BandScale.astro";
import type { Band, Point, Segment } from "../lib/adafruit";

interface Props {
  id: string;
  label: string;
  unit: string;
  stroke: string;
  fill: string;
  feedKey: string;
  defaultRange: string;
  scale: Segment[];
  // Data props are optional: when omitted the card renders a loading
  // placeholder and the client scripts fill it in once the live fetch lands.
  latest?: number;
  band?: Band;
  points?: Point[];
  historyPoints?: Point[];
}
const {
  id,
  label,
  unit,
  stroke,
  fill,
  feedKey,
  defaultRange,
  scale,
  latest,
  band,
  points = [],
  historyPoints = [],
} = Astro.props;

const bg: Record<Band, string> = {
  cold: "bg-blue",
  cool: "bg-blue",
  comfortable: "bg-green",
  warm: "bg-pink",
  hot: "bg-pink",
};

// No band yet means we're still loading: a neutral, gently pulsing card.
const cardClass = band ? bg[band] : "bg-light-grey animate-pulse";
---

<article
  class={`${cardClass} rounded-2xl p-[clamp(1rem,3vh,2rem)] flex flex-col gap-[clamp(0.5rem,1.5vh,1rem)] transition-colors`}
  aria-busy={band ? undefined : "true"}
>
  <h2 class="font-sans text-xs uppercase tracking-widest text-grey m-0">{label}</h2>
  <div class="flex items-baseline gap-2">
    <span
      data-value={id}
      class="font-serif leading-none tabular-nums text-[clamp(2.75rem,9vw,4.5rem)]"
    >
      {latest != null ? latest.toFixed(1) : "—"}
    </span>
    <span class="font-serif text-2xl text-grey">{unit}</span>
  </div>
  <BandScale id={id} segments={scale} current={band} unit={unit} />
  <Sparkline points={points} stroke={stroke} fill={fill} unit={unit} id={id} />
  <HistoryPanel
    id={id}
    unit={unit}
    stroke={stroke}
    fill={fill}
    points={historyPoints}
    defaultRange={defaultRange}
    feedKey={feedKey}
  />
</article>
